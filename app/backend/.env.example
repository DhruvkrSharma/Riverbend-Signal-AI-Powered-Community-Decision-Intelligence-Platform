# Copy to .env (or export in your shell) — NEVER commit real secrets.

# Enables live Gemini-powered answers on /api/ask. Without it, the app still
# runs using the local heuristic engine. Get a key: https://aistudio.google.com/
GEMINI_API_KEY=

# Optional: Gemini model id (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# CORS allowlist for the API (comma-separated origins). Lock this to your real
# frontend origin(s) in production.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional: per-IP rate-limit bucket capacity (default 60)
# RATE_LIMIT=60
